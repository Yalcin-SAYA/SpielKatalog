        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjektGameKatalog"
        mc:Ignorable="d"
        Title="RPGMenu" Height="450" Width="800">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="C:\Users\yalci\Downloads\WPF Projekt Sahan\WPF Projekt Sahan\ProjektGameKatalog Sahan\ProjektGameKatalog\ProjektGameKatalog\Images\RPGMenü.webp"/>
