<Window x:Class="ProjektGameKatalog.Katalog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjektGameKatalog"
        mc:Ignorable="d"
        Title="Katalog" Height="450" Width="800">

    <Window.Background>
        <ImageBrush ImageSource="C:\Users\yalci\Downloads\WPF Projekt Sahan\WPF Projekt Sahan\ProjektGameKatalog Sahan\ProjektGameKatalog\ProjektGameKatalog\Images\katalogBG.avif"/>
    </Window.Background>


    <Canvas>
        <!-- Username Label oben links -->
        <Label x:Name="UsernameLabel" Content="Username" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10"
       Foreground="Black" FontSize="12" FontWeight="Normal"/>

        <!-- Abmelden Button rechts oben -->
        <Button Content="Abmelden" Width="80" Height="24" HorizontalAlignment="Right" VerticalAlignment="Top" 
        Click="LogoutButton_Click" Canvas.Left="10" Canvas.Top="62"/>

        <!-- StackPanel für Spiel-Buttons links -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Top" Canvas.Left="325" Canvas.Top="170">
            <Button Content="Space Shooter" Width="150" Height="40"  Click="Spiel1_Click"/>
            <Button Content="Pacman" Width="150" Height="40" Margin="0,5" Click="Spiel2_Click"/>
            <Button Content="RPG" Width="150" Height="40" Click="Spiel3_Click"/>
        </StackPanel>
    </Canvas>
</Window>
